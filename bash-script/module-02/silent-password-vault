#!/bin/bash
# ╔══════════════════════════════════════════╗
# ║  Project #5 — Silent Password Vault      ║
# ║  Topics: read -sp, ${#}, validation,     ║
# ║          regex match, sha256sum, readonly ║
# ╚══════════════════════════════════════════╝

readonly MIN_LEN=8
readonly VAULT_FILE="$HOME/.vault_store"

# ── 1. username input (read -p) ────────────────────────────
read -p "Username: " username

if [[ -z "${username}" ]]; then
    echo "[ERROR] Username cannot be empty."
    exit 1
fi

if [[ ! "${username}" =~ ^[a-zA-Z0-9_]+$ ]]; then
    echo "[ERROR] Username: letters, digits, underscore only."
    exit 1
fi

# ── 2. silent password input (read -sp) ────────────────────
read -sp "Password: " passwd
echo ""    # newline — always needed after -s

if [[ -z "${passwd}" ]]; then
    echo "[ERROR] Password cannot be empty."
    exit 1
fi

# ── 3. length validation using ${#passwd} ──────────────────
if (( ${#passwd} < MIN_LEN )); then
    echo "[ERROR] Password too short. Minimum: ${MIN_LEN} chars. Got: ${#passwd}"
    exit 1
fi

# ── 4. confirm password (second read -sp) ──────────────────
read -sp "Confirm password: " passwd2
echo ""

if [[ "${passwd}" != "${passwd2}" ]]; then
    echo "[ERROR] Passwords do not match."
    exit 1
fi

# ── 5. strength check (regex pattern matching) ─────────────
strength="weak"
has_upper=false
has_digit=false
has_special=false

[[ "${passwd}" =~ [A-Z] ]]       && has_upper=true
[[ "${passwd}" =~ [0-9] ]]       && has_digit=true
[[ "${passwd}" =~ [^a-zA-Z0-9] ]] && has_special=true

if $has_upper && $has_digit && $has_special; then
    strength="strong"
elif $has_upper || $has_digit; then
    strength="medium"
fi

# ── 6. hash and store ──────────────────────────────────────
hash=$(echo -n "${passwd}" | sha256sum | cut -d' ' -f1)
timestamp=$(date)

echo "${username}:${hash}:${timestamp}" >> "${VAULT_FILE}"

# ── 7. result output ───────────────────────────────────────
echo ""
echo "╔══════════════════════════════════════╗"
echo "║         VAULT ENTRY SAVED            ║"
echo "╠══════════════════════════════════════╣"
echo "  User      : ${username}"
echo "  Length    : ${#passwd} characters"
echo "  Strength  : ${strength}"
echo "  SHA256    : ${hash:0:16}..."
echo "  Stored at : ${VAULT_FILE}"
echo "  Timestamp : ${timestamp}"
echo "╚══════════════════════════════════════╝"